# ObserveClaw Configuration
# Copy to .env and fill in your values

# Gateway connection (required)
GATEWAY_URL=ws://127.0.0.1:18789
GATEWAY_TOKEN=
GATEWAY_PASSWORD=

# Server
OBSERVECLAW_PORT=3001
OBSERVECLAW_HOST=0.0.0.0

# Authentication (recommended — secures the dashboard)
OBSERVECLAW_OPERATOR_PASSWORD=

# Optional: Telegram notifications
# OBSERVECLAW_TELEGRAM_BOT_TOKEN=
# OBSERVECLAW_TELEGRAM_CHAT_ID=

# Optional: override OpenClaw dist directory (auto-detected if omitted)
# OPENCLAW_DIST_DIR=
